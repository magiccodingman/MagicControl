@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject DashboardService Dashboard

<PageTitle>Dashboard - MagicControl</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Control plane dashboard</MudText>
<MudText Typo="Typo.body1" Class="mb-8">
    The foundation is online. Enrollment, identity, users, and database state now have a real home.
</MudText>

@if (_summary is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-5">
                <MudText Typo="Typo.overline">Users</MudText>
                <MudText Typo="Typo.h3">@_summary.Users</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-5">
                <MudText Typo="Typo.overline">Pending applications</MudText>
                <MudText Typo="Typo.h3">@_summary.PendingApplications</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-5">
                <MudText Typo="Typo.overline">Pending Mesh APIs</MudText>
                <MudText Typo="Typo.h3">@_summary.PendingMeshApis</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-5">
                <MudText Typo="Typo.overline">Managed applications</MudText>
                <MudText Typo="Typo.h3">@_summary.ManagedApplications</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-5">
                <MudText Typo="Typo.overline">Managed Mesh APIs</MudText>
                <MudText Typo="Typo.h3">@_summary.ManagedMeshApis</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private DashboardSummary? _summary;

    protected override async Task OnInitializedAsync()
        => _summary = await Dashboard.GetAsync();
}
